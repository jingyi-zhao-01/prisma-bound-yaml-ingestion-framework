generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trade {
  id        String   @id
  price     Float
  amount    Float?
  timestamp DateTime
  symbol    String
  side      String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id          String   @id
  orderId     String   @unique
  price       Float
  quantity    Float
  filledQty   Float    @default(0)
  status      String   @default("new")
  orderType   String
  side        String
  symbol      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Position {
  id           String   @id
  symbol       String
  quantity     Float
  avgPrice     Float
  unrealizedPnL Float   @default(0)
  realizedPnL  Float    @default(0)
  updatedAt    DateTime @updatedAt
}

model Market {
  id          String   @id
  symbol      String   @unique
  name        String
  baseAsset   String
  quoteAsset  String
  price       Float
  volume24h   Float    @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
